# ─── E-mail (Resend) ─────────────────────────────────────────
# Crie conta gratuita em https://resend.com (3.000 e-mails/mês grátis)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# E-mail remetente (from).
# Sem domínio verificado: use onboarding@resend.dev (domínio compartilhado Resend)
# Com domínio verificado: use contato@nerdzone.com.br
RESEND_FROM_EMAIL=onboarding@resend.dev

# E-mail de destino dos formulários de contato
CONTACT_EMAIL=contato@nerdzone.com.br

# ─── ERPSystem ───────────────────────────────────────────────
# URL de login do ERPSystem em produção
NEXT_PUBLIC_ERP_LOGIN_URL=https://app.nerdzone.com.br/login
